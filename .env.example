# =============================================================================
# MeetingForge - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# =============================================================================

# --- Whisper ---
# Tamaño del modelo: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=medium
# Dispositivo: cpu | cuda | auto
WHISPER_DEVICE=auto
# Tipo de cómputo: int8 (CPU seguro) | float16 (GPU) | float32
# Default int8 para que arranque en CPU. Sube a float16 si tienes GPU.
WHISPER_COMPUTE_TYPE=int8
# Idioma del audio (código ISO, p.ej. es, en). Vacío/omitir = autodetección.
# WHISPER_LANGUAGE=es
# Preprocesado opcional del audio con ffmpeg (mono + 16 kHz + loudnorm) antes de transcribir
AUDIO_PREPROCESS_ENABLED=false

# --- LLM Provider ---
# Proveedor activo: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# --- API Keys ---
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OLLAMA_BASE_URL=http://localhost:11434
# Reintentos ante errores transitorios del LLM (rate limit, timeout, 5xx)
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# --- Modelos específicos ---
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-2024-08-06
OLLAMA_MODEL=llama3.1:8b

# --- RAG ---
# Activa/desactiva el uso de RAG en el extractor (true | false)
RAG_ENABLED=true
# Directorio externo de documentación a indexar (opcional, además del repo)
# DOCS_PATH=C:/path/to/your/docs
# Modelo de embeddings (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Nombre de la colección en ChromaDB
CHROMA_COLLECTION=meeting_forge_docs
# Top-K chunks finales pasados al extractor
RETRIEVAL_TOP_K=5
# Top-K por cada ventana del transcript
RETRIEVAL_PER_QUERY_K=3
# Tamaño máximo de cada chunk (en caracteres)
CHUNK_MAX_CHARS=1500
# Solapamiento entre chunks divididos por tamaño
CHUNK_OVERLAP_CHARS=200
# Tamaño de ventana del transcript para hacer queries
TRANSCRIPT_QUERY_CHARS=500
# Tope de caracteres del bloque de contexto enviado al LLM
CONTEXT_MAX_CHARS=8000

# --- Generation (Fase 2) ---
# Activa/desactiva la generación de documentos (true | false)
GENERATION_ENABLED=true
# Modos habilitados (CSV): adr-per-decision, adr-consolidated, acta, roadmap-update, technical-doc-update
GENERATION_MODES=adr-per-decision,acta
# Versión del prompt de ADR a usar
ADR_PROMPT_VERSION=v1
# Máximo de tokens para las llamadas LLM de generación
GENERATION_MAX_TOKENS=4000
# Documentos existentes a actualizar (modos roadmap-update / technical-doc-update).
# Si se definen, el pipeline propone un diff sobre ellos; si no, crea uno nuevo.
# ROADMAP_PATH=C:/path/to/docs/ROADMAP.md
# TECH_DOC_PATH=C:/path/to/docs/ARCHITECTURE.md

# --- Git Integration (Fase 4) ---
# Activa/desactiva la integración Git (true | false, default false)
GIT_INTEGRATION_ENABLED=false
# Ruta local del repositorio destino donde publicar los documentos
# GIT_TARGET_REPO_PATH=C:/path/to/your/docs-repo
# URL del remote git para clonar si el repo no existe localmente (opcional)
# GIT_TARGET_REMOTE=https://github.com/org/docs-repo.git
# Subdirectorio dentro del repo destino donde se colocarán los docs
GIT_DOCS_SUBDIR=docs/meetings
# Rama base del repo destino (normalmente main o master)
GIT_BASE_BRANCH=main
# Prefijo para las ramas creadas por MeetingForge
GIT_BRANCH_PREFIX=meeting-forge/
# Ejecutable de gh CLI (útil si está en un path no estándar)
GH_EXECUTABLE=gh
# Crea los Pull Requests como borrador (raíl recomendado para el modo automático)
GIT_PR_DRAFT=false

# --- Automatización opcional (Fase C · F8) ---
# Desactivado por defecto (con HITL apruebas a mano). Si se activa, solo se auto-aprueban los tipos
# de AUTO_APPROVE_KINDS (default: solo actas). La auto-publicación exige además AUTO_PUBLISH_ENABLED
# y GIT_INTEGRATION_ENABLED (y respeta GIT_PR_DRAFT).
AUTO_APPROVE_ENABLED=false
AUTO_APPROVE_KINDS=acta
AUTO_PUBLISH_ENABLED=false

# --- Logging ---
LOG_LEVEL=INFO

# =============================================================================
# MeetingForge - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# =============================================================================

# --- Whisper ---
# Tamaño del modelo: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=medium
# Dispositivo: cpu | cuda | auto
WHISPER_DEVICE=auto
# Tipo de cómputo: int8 (CPU seguro) | float16 (GPU) | float32
# Default int8 para que arranque en CPU. Sube a float16 si tienes GPU.
WHISPER_COMPUTE_TYPE=int8

# --- LLM Provider ---
# Proveedor activo: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# --- API Keys ---
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OLLAMA_BASE_URL=http://localhost:11434

# --- Modelos específicos ---
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-2024-08-06
OLLAMA_MODEL=llama3.1:8b

# --- RAG ---
# Activa/desactiva el uso de RAG en el extractor (true | false)
RAG_ENABLED=true
# Directorio externo de documentación a indexar (opcional, además del repo)
# DOCS_PATH=C:/path/to/your/docs
# Modelo de embeddings (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Nombre de la colección en ChromaDB
CHROMA_COLLECTION=meeting_forge_docs
# Top-K chunks finales pasados al extractor
RETRIEVAL_TOP_K=5
# Top-K por cada ventana del transcript
RETRIEVAL_PER_QUERY_K=3
# Tamaño máximo de cada chunk (en caracteres)
CHUNK_MAX_CHARS=1500
# Solapamiento entre chunks divididos por tamaño
CHUNK_OVERLAP_CHARS=200
# Tamaño de ventana del transcript para hacer queries
TRANSCRIPT_QUERY_CHARS=500
# Tope de caracteres del bloque de contexto enviado al LLM
CONTEXT_MAX_CHARS=8000

# --- Logging ---
LOG_LEVEL=INFO
